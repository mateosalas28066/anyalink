// secrets.h.example
// Copiar a secrets.h y rellenar con valores reales. NO commitear secrets.h.
//
// (ES) Configuración WiFi: WiFiMulti acepta varias redes y elige la mejor.
// Si una contraseña es "" => red abierta.

#pragma once

struct WifiNetwork {
  const char* ssid;
  const char* password;
};

static const WifiNetwork WIFI_NETWORKS[] = {
  {"ARRIS-EAFF",  "tu_password_casa"},
  {"USC-LIBRE",   ""},
  {"USC-SALONES", ""},
  {"Estudiantes", ""}
};

// ======== MQTT (broker local en tu PC) ========
// IP local de tu máquina en la LAN donde corre Mosquitto.
// En Windows obtenela con: ipconfig | findstr IPv4
#define MQTT_HOST       "192.168.1.100"
#define MQTT_PORT       1883
#define MQTT_USER       ""              // vacío = anonymous (Plan 1 deja Mosquitto sin auth)
#define MQTT_PASSWORD   ""

// ======== Identidad del dispositivo ========
// UUID de la fila en Supabase devices (alias='Dispensador').
// Lo generás cuando corrés la migration 0001_mvp_esp32.sql.
#define DEVICE_ID       "00000000-0000-0000-0000-000000000000"
